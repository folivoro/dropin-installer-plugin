{
    "name": "folivoro/composer-dropin-installer",
    "description": "Copies a single file from a package into a target directory defined by installer-paths.",
    "type": "composer-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Ben Kremer",
            "email": "ben@folivoro.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "composer-plugin-api": "^2.0"
    },
    "require-dev": {
        "composer/composer": "^2.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Folivoro\\ComposerDropinInstaller\\": "src/"
        }
    },
    "extra": {
        "class": "Folivoro\\ComposerDropinInstaller\\DropinInstallerPlugin"
    },
    "config": {
        "allow-plugins": {
            "folivoro/composer-dropin-installer": true
        },
        "sort-packages": true
    }
}
